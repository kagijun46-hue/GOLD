# === XAUUSD Trading Assistant - Environment Variables ===
#
# 使い方:
#   cp .env.example .env.local
#   .env.local を編集して設定する
#
# ================================================================

# ----------------------------------------------------------------
# [必須] Twelve Data API キー
# 取得: https://twelvedata.com/ → Sign Up → API Keys
# 無料プラン: 800req/日、8req/分（本アプリのMVPは十分動作）
# ----------------------------------------------------------------
TWELVE_DATA_API_KEY=your_key_here

# ----------------------------------------------------------------
# [任意] データモード切り替え
# true  → ダミーデータ（APIキー不要、オフラインで動作）
# false → Twelve Data 実データ（上記APIキーが必要）
# ----------------------------------------------------------------
NEXT_PUBLIC_USE_DUMMY_DATA=true

# ----------------------------------------------------------------
# [任意] データ自動更新間隔（秒）
# 無料プランの場合は 60 以上を推奨（レート制限対策）
# ----------------------------------------------------------------
NEXT_PUBLIC_REFRESH_INTERVAL=60

# ----------------------------------------------------------------
# [将来] 通知API（現時点では未実装）
# ----------------------------------------------------------------
# LINE Notify: https://notify-bot.line.me/
# LINE_NOTIFY_TOKEN=your_token_here

# Telegram Bot: https://core.telegram.org/bots/api
# TELEGRAM_BOT_TOKEN=your_token_here
# TELEGRAM_CHAT_ID=your_chat_id_here
