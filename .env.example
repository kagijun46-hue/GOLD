# === XAUUSD Trading Assistant - Environment Variables ===

# --- Market Data APIs ---
# Alpha Vantage (無料プランあり): https://www.alphavantage.co/
ALPHA_VANTAGE_API_KEY=your_key_here

# Twelve Data (無料プランあり): https://twelvedata.com/
TWELVE_DATA_API_KEY=your_key_here

# Yahoo Finance (非公式): 追加設定不要の場合もあり
# YAHOO_FINANCE_PROXY_URL=

# --- Notification APIs (将来実装) ---
# LINE Notify: https://notify-bot.line.me/
# LINE_NOTIFY_TOKEN=your_token_here

# Telegram Bot: https://core.telegram.org/bots/api
# TELEGRAM_BOT_TOKEN=your_token_here
# TELEGRAM_CHAT_ID=your_chat_id_here

# --- App Settings ---
# データ取得間隔（秒）
NEXT_PUBLIC_REFRESH_INTERVAL=60

# ダミーデータ使用フラグ（true=ダミー, false=実API）
NEXT_PUBLIC_USE_DUMMY_DATA=true
